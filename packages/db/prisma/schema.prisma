generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      Role     @default(USER)
  agencies  Agency[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
  AGENCY_OWNER
}

model Agency {
  id          String       @id @default(cuid())
  name        String
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id])
  clients     Client[]
  metaConfigs MetaConfig[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  leads     Lead[]
  sales     Sale[]
  pixelId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MetaConfig {
  id          String  @id @default(cuid())
  agencyId    String
  agency      Agency  @relation(fields: [agencyId], references: [id])
  accessToken String
  appId       String
  pixelId     String?
  isActive    Boolean @default(true)
}

model Lead {
  id           String   @id @default(cuid())
  email        String?
  phone        String?
  name         String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  ip           String?
  userAgent    String?
  fbp          String?
  fbc          String?
  capturedDate DateTime @default(now())
}

model Sale {
  id         String   @id @default(cuid())
  amount     Float
  currency   String   @default("BRL")
  sku        String?
  origin     String?
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id])
  saleDate   DateTime @default(now())
  orderId    String?  @unique
  status     String   @default("COMPLETED")
}
